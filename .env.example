# Copy this file to .env and fill in your real credentials.
# .env is gitignored and must never be committed.
# Single-quote any value that contains a $ or # character.

# --- XTS Interactive (order placement / OMS broker) ---
# Consumed by config.yaml (${XTS_APP_KEY} etc.) via oms/config.py
XTS_APP_KEY='your-interactive-app-key'
XTS_SECRET_KEY='your-interactive-secret-key'
XTS_CLIENT_ID='your-client-id'          # only needed for dealer/CTCL mode

# --- XTS Marketdata (LTP quotes + master file downloads) ---
# Consumed by market_data/ (atm + download_masters)
XTS_MD_API_KEY='your-marketdata-app-key'
XTS_MD_API_SECRET='your-marketdata-secret-key'
XTS_MD_SOURCE='WEBAPI'
XTS_MD_REST_URL='https://eztrade.wealthdiscovery.in/apimarketdata'

# --- eXchange1 (crypto spot via OMS crypto_broker) ---
# Base URL must match your exchange OpenAPI host (see their API docs).
# Official Exchange1 docs: https://openapi.exchange1.com — use /sapi/v1/... paths.
EXCHANGE1_API_KEY='your-exchange1-api-key'
EXCHANGE1_API_SECRET='your-exchange1-hmac-secret'
EXCHANGE1_URL='https://openapi.exchange1.com'
