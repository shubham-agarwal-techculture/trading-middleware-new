# Copy to .env and adjust as needed.

# Port for this webhook + dashboard process
SIGNAL_PORT=5001

# Python bridge (signal ingress)
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=5002

# Absolute URL the browser dashboard uses to call the bridge
# (defaults to http://BRIDGE_HOST:BRIDGE_PORT when unset)
# BRIDGE_API_BASE=http://127.0.0.1:5002
